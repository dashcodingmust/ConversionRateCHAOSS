import requests

def lastCommitTime(commits,owner,repo):
    #The requests library calls the github api and to run this program a stable internet connection
    url = f"https://api.github.com/repos/{owner}/{repo}/commits?per_page={commits}" 
    response = requests.get(url)

    #This print out the date of the last of commit, this will help identify if this project is still being worked on
    last_commit = response.json()[0]
    print(last_commit["commit"]['author']['date']) 
